# 只读客户端构建配置。EdgeOne同项目部署通常留空，页面会使用当前站点origin。
CLOUD_COLLAB_API_BASE=

# 阶段4B.2隔离预览写总开关。默认必须关闭。
CLOUD_COLLAB_WRITE_PREVIEW_ENABLED=false

# 仅配置在EdgeOne项目环境变量中；至少32字节随机值。不要提交真实值到GitHub、HTML或聊天记录。
CLOUD_COLLAB_WRITE_PREVIEW_KEY=

# 仅用于合成测试设备与候选，不得与未来正式公共数据命名空间共用。
CLOUD_COLLAB_PRIVATE_BLOB_STORE=cloud-collab-preview-private
