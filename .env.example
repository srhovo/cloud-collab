# 只读客户端构建配置。EdgeOne同项目部署通常留空，页面会使用当前站点origin。
CLOUD_COLLAB_API_BASE=

# 阶段4B设备注册服务端开关。正式密钥配置和验收前必须保持false。
CLOUD_COLLAB_DEVICE_REGISTRATION_ENABLED=false

# 仅配置在EdgeOne项目环境变量中；至少32字节随机值。不要提交真实值到GitHub。
CLOUD_COLLAB_DEVICE_TOKEN_SECRET=

# 可选。Blob命名空间首次使用时由EdgeOne自动创建。
CLOUD_COLLAB_DEVICE_STORE_NAME=cloud-collab-private
