# 通常留空：同项目部署时，客户端自动使用当前站点 origin。
CLOUD_COLLAB_API_BASE=

# 阶段4B.2预览写入开关。默认必须为0；仅在隔离验收部署临时改为1。
CLOUD_WRITE_PREVIEW_ENABLED=0

# 至少32字节随机值，只保存在EdgeOne环境变量中；不要提交真实值到GitHub、HTML、截图或聊天。
CLOUD_WRITE_PREVIEW_KEY=

# 作用域被代码硬锁为以下合成测试库；改成任何其他值都会拒绝启动。
CLOUD_WRITE_ALLOWED_GROUP_ID=group_fixture
CLOUD_WRITE_ALLOWED_LIBRARY_ID=lib_receive_fixture

# EdgeOne Makers Blob隔离预览命名空间，不得与未来正式公共数据共用。
CLOUD_BLOB_STORE_NAME=cloud-collab-preview-v1

# 至少32字节随机值，只用于限流主体Hash；不要复用预览访问密钥。
CLOUD_RATE_LIMIT_SALT=

# 阶段4C一次性清理工具。默认必须为0，且不能与预览写入同时开启。
CLOUD_PREVIEW_CLEANUP_ENABLED=0

# 至少32字节随机值，只用于一次性清理；不得复用预览写入密钥或限流盐值。
# 真实值只保存在EdgeOne部署环境中，不得提交、截图或发送到聊天。
CLOUD_PREVIEW_CLEANUP_KEY=

# 仅在一次性清理窗口由部署环境临时设置固定确认词；仓库示例必须保持空白。
CLOUD_PREVIEW_CLEANUP_CONFIRMATION=
