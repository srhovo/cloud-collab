# 通常留空：同项目部署时，客户端自动使用当前站点 origin。
CLOUD_COLLAB_API_BASE=

# 阶段4B.2预览写入开关。默认必须为0；仅在隔离验收部署临时改为1。
CLOUD_WRITE_PREVIEW_ENABLED=0

# 阶段4E自动审核预览开关。默认必须为0；只有与写入开关同时为1时才允许合成测试库生成动态事件和快照。
CLOUD_AUTO_APPROVAL_PREVIEW_ENABLED=0

# 至少32字节随机值，只保存在EdgeOne环境变量中；不要提交真实值到GitHub、HTML、截图或聊天。
CLOUD_WRITE_PREVIEW_KEY=

# 作用域被代码硬锁为以下合成测试库；改成任何其他值都会拒绝启动。
CLOUD_WRITE_ALLOWED_GROUP_ID=group_fixture
CLOUD_WRITE_ALLOWED_LIBRARY_ID=lib_receive_fixture

# EdgeOne Makers Blob隔离预览命名空间，不得与未来正式公共数据共用。
CLOUD_BLOB_STORE_NAME=cloud-collab-preview-v1

# 至少32字节随机值，只用于限流主体Hash；不要复用预览访问密钥。
CLOUD_RATE_LIMIT_SALT=

# 阶段5G普通陪玩名字与老板资料预览。默认必须为0；关闭时现有exact_price链路行为不得变化。
CLOUD_ORDINARY_TYPES_PREVIEW_ENABLED=0

# 阶段5G数据源继续硬锁阶段4合成预览Blob和fixture作用域，不得指向正式公共库。
CLOUD_ORDINARY_TYPES_BLOB_STORE_NAME=cloud-collab-preview-v1
CLOUD_ORDINARY_TYPES_ALLOWED_GROUP_ID=group_fixture
CLOUD_ORDINARY_TYPES_ALLOWED_LIBRARY_ID=lib_receive_fixture

# 阶段5A管理员登录预览开关。默认必须为0；只允许在独立管理员预览部署中临时设为1。
CLOUD_ADMIN_PREVIEW_ENABLED=0

# 管理员页面的公开HTTPS来源，只填协议和域名，不含路径、查询参数或预览token；EdgeOne同项目轮换部署域名可复用。
CLOUD_ADMIN_PUBLIC_ORIGIN=

# 管理员用户名与密码只配置在EdgeOne私密环境变量中。真实值不得进入GitHub、HTML、日志、截图或聊天。
CLOUD_ADMIN_USERNAME=
CLOUD_ADMIN_PASSWORD=

# 至少32字节且彼此不同；会话密钥用于15分钟HS256会话，限流盐值只用于Hash登录主体。
CLOUD_ADMIN_SESSION_SECRET=
CLOUD_ADMIN_RATE_LIMIT_SALT=

# 阶段5A登录限流独立Blob命名空间；代码硬锁此值，不得与公共数据或阶段4预览库共用。
CLOUD_ADMIN_BLOB_STORE_NAME=cloud-collab-admin-preview-v1

# 阶段5B管理员只读审核预览。默认必须为0；仅允许独立合成验收环境临时设为1。
CLOUD_ADMIN_REVIEW_PREVIEW_ENABLED=0

# 阶段5B只读审核数据源硬锁为阶段4合成预览命名空间，不得指向正式公共库。
CLOUD_ADMIN_REVIEW_BLOB_STORE_NAME=cloud-collab-preview-v1
CLOUD_ADMIN_REVIEW_ALLOWED_GROUP_ID=group_fixture
CLOUD_ADMIN_REVIEW_ALLOWED_LIBRARY_ID=lib_receive_fixture

# 阶段5C管理员审核写入预览。默认必须为0；只允许5B/5C合并隔离验收临时设为1。
CLOUD_ADMIN_REVIEW_MUTATION_PREVIEW_ENABLED=0

# 阶段5D管理员设备治理预览。默认必须为0；启用时公共写入、自动审核和阶段5C审核写入必须保持0。
CLOUD_ADMIN_DEVICE_GOVERNANCE_PREVIEW_ENABLED=0

# 阶段5D继续硬锁阶段4合成预览Blob；不得指向正式公共库或管理员登录限流库。
CLOUD_ADMIN_DEVICE_GOVERNANCE_BLOB_STORE_NAME=cloud-collab-preview-v1

# 至少32字节，仅用于生成不可逆deviceRef；必须与管理员密码、会话密钥、限流盐值和公共预览凭据不同。
CLOUD_ADMIN_DEVICE_REF_SALT=

# 阶段5E管理员回滚预览。默认必须为0；启用时公共写入、自动审核和阶段5C审核写入必须保持0。
CLOUD_ADMIN_ROLLBACK_PREVIEW_ENABLED=0

# 阶段5E继续硬锁合成预览Blob和fixture作用域，不得指向正式公共库。
CLOUD_ADMIN_ROLLBACK_BLOB_STORE_NAME=cloud-collab-preview-v1
CLOUD_ADMIN_ROLLBACK_ALLOWED_GROUP_ID=group_fixture
CLOUD_ADMIN_ROLLBACK_ALLOWED_LIBRARY_ID=lib_receive_fixture

# 至少32字节，仅用于生成不可逆rollbackRef；不得复用任何管理员、设备或公共预览凭据。
CLOUD_ADMIN_ROLLBACK_REF_SALT=

# 阶段5F管理员标准导出预览。默认必须为0；仅在设备治理、回滚与导出联合验收中临时设为1。
CLOUD_ADMIN_EXPORT_PREVIEW_ENABLED=0

# 阶段5F只读取合成公共Blob和fixture作用域，不得指向正式公共库。
CLOUD_ADMIN_EXPORT_BLOB_STORE_NAME=cloud-collab-preview-v1
CLOUD_ADMIN_EXPORT_ALLOWED_GROUP_ID=group_fixture
CLOUD_ADMIN_EXPORT_ALLOWED_LIBRARY_ID=lib_receive_fixture

# 至少32字节，仅用于不可逆导出请求索引与私有审计关联；不得复用其他凭据。
CLOUD_ADMIN_EXPORT_AUDIT_SALT=
