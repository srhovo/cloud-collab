{
  "schemaVersion": 1,
  "serviceId": "cloud-collab-readonly",
  "apiVersion": "2026-07-18",
  "protocolVersion": 1,
  "writeEnabled": false,
  "endpoints": [
    {
      "method": "GET",
      "path": "/api/health",
      "cache": "no-store",
      "authentication": "none",
      "responseData": ["status", "environment", "serverTime", "protocolVersion", "writeEnabled", "capabilities"]
    },
    {
      "method": "GET",
      "path": "/api/protocol",
      "cacheSeconds": 300,
      "authentication": "none",
      "responseData": ["protocolVersion", "minimumClientProtocolVersion", "latestClientProtocolVersion", "publicDataSchemaVersion", "submissionSchemaVersion", "localCloudStoreSchemaVersion", "writeEnabled", "polling", "capabilities"]
    },
    {
      "method": "GET",
      "path": "/api/public-version?groupId={groupId}&libraryId={libraryId}",
      "cacheSeconds": 300,
      "authentication": "none",
      "responseData": ["groupId", "libraryId", "publicVersion", "snapshotVersion", "updatedAt", "status", "snapshotAvailable", "recordCounts", "writeEnabled"]
    }
  ],
  "cors": {
    "allowOrigin": "*",
    "allowMethods": ["GET", "HEAD", "OPTIONS"],
    "credentials": false
  },
  "forbidden": [
    "POST/PUT/PATCH/DELETE",
    "Authorization header",
    "deviceId or deviceToken",
    "submission",
    "snapshot contents",
    "administrator write operations",
    "business prices or user records in the Stage3A test catalog"
  ]
}
